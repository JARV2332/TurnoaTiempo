# Supabase - Obligatorios para que la app funcione
# Cópialo a .env.local y rellena con los valores de tu proyecto en https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui

# Opcional (recomendado en producción): URL exacta para confirmación por correo
# NEXT_PUBLIC_AUTH_EMAIL_REDIRECT_URL=https://tu-dominio.com/auth/login
#
# Alternativa: URL base del sitio. La app usará: NEXT_PUBLIC_SITE_URL + /auth/login
# NEXT_PUBLIC_SITE_URL=https://tu-dominio.com
