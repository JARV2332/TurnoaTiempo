# Supabase - Obligatorios para que la app funcione
# Cópialo a .env.local y rellena con los valores de tu proyecto en https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui

# Opcional: URL de redirección tras confirmar email (registro)
# Si no la pones, se usará automáticamente: tu-origen/auth/login
# NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/auth/login
